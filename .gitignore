# Secrets
.env

# Pipeline runtime state
.pipeline_state.json

# Generated media (can be large)
downloads/
clips/
output/
videos/

# Modelo de MediaPipe (se descarga solo en runtime; ~3.6 MB)
models/

# Cache de forma de onda del editor de timeline (se recomputa si falta)
*.peaks.json

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Node / Remotion
remotion/node_modules/
remotion/out/
components/clip_editor/frontend/node_modules/
*.tsbuildinfo

# Custom Streamlit component (Track 2): los assets COMPILADOS deben versionarse
# para desplegar sin `npm run build`. La regla global `build/` de arriba los
# excluiría; esta negación los rescata. Ver docs/DEPLOYMENT.md.
!components/clip_editor/frontend/build/
!components/clip_editor/frontend/build/**

# Generated outputs
*.csv

# Legacy scripts
script.py

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/
