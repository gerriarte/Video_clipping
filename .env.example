# Copiá este archivo como .env y completá los valores.
# En Windows también podés usar: set ANTHROPIC_API_KEY=tu_key
# Todas estas variables se leen en config.py.

# ── Proveedor de LLM ──────────────────────────────────────────────────────────
# "anthropic" (nube, mejor calidad) u "ollama" (local, gratis y privado).
LLM_PROVIDER=anthropic

# ── Anthropic (requerido si LLM_PROVIDER=anthropic) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-6

# ── Ollama (solo si LLM_PROVIDER=ollama) ──────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=600
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX_ANALYZE=32768

# ── Postiz (opcional — programar publicaciones desde el Paso 6) ───────────────
# Self-hosted: la base termina en /api/public/v1
POSTIZ_API_URL=https://redes.abralatam.com/api/public/v1
POSTIZ_API_KEY=
